# ==========================================
# Open Anime API Configuration Skeleton
# ==========================================

# Database Mode: "local" (saves to local JSON file) or "supabase" (saves to Supabase)
DB_MODE=local
LOCAL_DB_PATH=anime_links.json

# Supabase Credentials (If using DB_MODE=supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Streaming Sources for HTTP Scrapers (Comma-separated)
GOGO_DOMAINS=https://gogoanimes.cv/,https://gogoanime.or.at/,https://gogoanime.ist/popular
ANIWAVE_CLUSTER=https://aniwave.com.pl/,https://aniwave.dk/anime/,https://gogoanime.ru.com/,https://www.anime-planet.com/anime/all,https://www.anime-planet.com/anime/watch-online/dubbed/,https://animedao.site/9anime/
HIANIME_CLUSTER=https://hianime.sk/home,https://animego.net/tv-series/

# Jikan API URL for Anime Metadata
JIKAN_API_URL=https://api.jikan.moe/v4

# Port to run the server on
PORT=3000
